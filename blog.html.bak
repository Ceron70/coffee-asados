<script>
    const API_URL_BLOG = 'https://script.google.com/macros/s/AKfycbwJsP99Dm66Ze9we6TQxdEfdazPIsAJBWBiF5mp4qPlmLZbskIFN1qwexWzDbaDmH0sVQ/exec';
    
    let articulosOriginales = [];
    let categoriaActual = 'todos';

    async function cargarArticulos() {
        const grid = document.getElementById('blog-grid');
        grid.innerHTML = '<div class="loading"><i class="fas fa-spinner fa-pulse"></i> Cargando artículos...</div>';
        
        try {
            const response = await fetch(API_URL_BLOG);
            const data = await response.json();
            console.log('Datos recibidos:', data);
            
            // CORRECCIÓN: usar 'datos' en lugar de 'articulos'
            if (data.success && data.datos && data.datos.length > 0) {
                articulosOriginales = data.datos;
                mostrarArticulos();
            } else {
                grid.innerHTML = '<div class="loading">No hay artículos disponibles por ahora.</div>';
            }
        } catch (error) {
            console.error('Error:', error);
            grid.innerHTML = '<div class="loading">Error al cargar los artículos.</div>';
        }
    }

    function mostrarArticulos() {
        const grid = document.getElementById('blog-grid');
        
        let articulosFiltrados = articulosOriginales;
        if (categoriaActual !== 'todos') {
            articulosFiltrados = articulosOriginales.filter(a => a.categoria === categoriaActual);
        }
        
        if (articulosFiltrados.length === 0) {
            grid.innerHTML = '<div class="loading">No hay artículos en esta categoría.</div>';
            return;
        }
        
        let html = '';
        for (let i = 0; i < articulosFiltrados.length; i++) {
            const articulo = articulosFiltrados[i];
            html += `
                <div class="articulo-card" onclick="verArticulo(${articulo.id})">
                    <img class="articulo-imagen" src="${articulo.imagen}" alt="${articulo.titulo}" loading="lazy" onerror="this.src='https://placehold.co/600x400?text=Imagen'">
                    <div class="articulo-info">
                        <span class="articulo-categoria">${articulo.categoria}</span>
                        <h3>${articulo.titulo}</h3>
                        <p>${articulo.resumen}</p>
                        <div class="articulo-fecha"><i class="far fa-calendar-alt"></i> ${articulo.fecha}</div>
                    </div>
                </div>
            `;
        }
        grid.innerHTML = html;
    }

    function verArticulo(id) {
        localStorage.setItem('articuloId', id);
        window.location.href = 'articulo.html';
    }

    document.querySelectorAll('.filtro-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.filtro-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            categoriaActual = this.getAttribute('data-categoria');
            mostrarArticulos();
        });
    });

    document.addEventListener('DOMContentLoaded', cargarArticulos);
</script>